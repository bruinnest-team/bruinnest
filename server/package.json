{
  "name": "bruinnest-server",
  "version": "1.0.0",
  "description": "BruinNest backend initialized with Express.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:seed": "node src/scripts/seedDb.js",
    "housing:import": "node src/scripts/importHousingData.js",
    "db:clean": "node src/scripts/cleanDb.js",
    "db:reset": "node src/scripts/cleanDb.js && node src/scripts/importHousingData.js && node src/scripts/seedDb.js"
  },
  "keywords": [],
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
